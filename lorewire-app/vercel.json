{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/drain_image_renders",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/drain_story_jobs",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/drain_voice_renders",
      "schedule": "*/1 * * * *"
    }
  ],
  "functions": {
    "api/drain_image_renders.py": {
      "maxDuration": 300
    },
    "api/drain_story_jobs.py": {
      "maxDuration": 300
    },
    "api/drain_voice_renders.py": {
      "maxDuration": 300
    }
  }
}
