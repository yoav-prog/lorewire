{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/drain_image_renders",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/drain_story_jobs",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/drain_voice_renders",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/render_video",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/drain_short_renders",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/render_short",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/polls/refresh",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/prune_magic_links",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/comments/drain_moderation",
      "schedule": "*/1 * * * *"
    }
  ],
  "functions": {
    "api/drain_image_renders.py": {
      "maxDuration": 300
    },
    "api/drain_story_jobs.py": {
      "maxDuration": 800
    },
    "api/drain_voice_renders.py": {
      "maxDuration": 300
    },
    "api/drain_short_renders.py": {
      "maxDuration": 800
    },
    "src/app/api/render_video/route.ts": {
      "maxDuration": 800
    },
    "src/app/api/render_short/route.ts": {
      "maxDuration": 800
    }
  }
}
