      "maxDuration": 300
    },
    "api/drain_story_jobs.py": {
      "maxDuration": 800
    },
    "api/drain_voice_renders.py": {
      "maxDuration": 300
    },
    "api/drain_short_renders.py": {
      "maxDuration": 800
    },
    "src/app/api/render_video/route.ts": {
      "maxDuration": 800
    },
    "src/app/api/render_short/route.ts": {
      "maxDuration": 800
    },
    "src/app/api/retry_facebook_publishes/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/retry_instagram_publishes/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/retry_facebook_stories/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/retry_instagram_stories/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/retry_youtube_publishes/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/retry_tiktok_publishes/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/auto_publish_full_pipeline/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/auto_complete_publish/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/refresh_assets/route.ts": {
      "maxDuration": 300
    },
    "api/run_hero_thumbnail_finisher.py": {
      "maxDuration": 800
    },
    "src/app/api/render_enqueue/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/expire_stale_reviews/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/publish_dispatch/route.ts": {
      "maxDuration": 300
    }
  }
