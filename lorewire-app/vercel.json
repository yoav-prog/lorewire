{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/drain_image_renders",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/drain_story_jobs",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/drain_voice_renders",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/render_video",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/drain_short_renders",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/render_short",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/polls/refresh",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/prune_magic_links",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/comments/drain_moderation",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/retry_facebook_publishes",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/retry_instagram_publishes",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/retry_facebook_stories",
      "schedule": "3-59/5 * * * *"
    },
    {
      "path": "/api/retry_instagram_stories",
      "schedule": "4-59/5 * * * *"
    },
    {
      "path": "/api/retry_youtube_publishes",
      "schedule": "1-59/5 * * * *"
    },
    {
      "path": "/api/retry_tiktok_publishes",
      "schedule": "2-59/5 * * * *"
    },
    {
      "path": "/api/auto_publish_full_pipeline",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/auto_complete_publish",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/refresh_assets",
      "schedule": "*/1 * * * *"
