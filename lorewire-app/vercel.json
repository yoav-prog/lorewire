{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/drain_image_renders",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/drain_story_jobs",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/drain_voice_renders",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/render_video",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/cleanup_curation_expired",
      "schedule": "0 3 * * *"
    }
  ],
  "functions": {
    "api/drain_image_renders.py": {
      "maxDuration": 300
    },
    "api/drain_story_jobs.py": {
      "maxDuration": 300
    },
    "api/drain_voice_renders.py": {
      "maxDuration": 300
    },
    "api/cleanup_curation_expired.py": {
      "maxDuration": 60
    },
    "src/app/api/render_video/route.ts": {
      "maxDuration": 800
    }
  }
}
