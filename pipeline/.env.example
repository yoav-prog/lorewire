# LoreWire pipeline — copy to .env and fill in ROTATED keys. Never commit real values.
# (.env is gitignored; .env.example is the safe-to-commit template.)

# --- Scrape: Reddit via Decodo proxy ---
DECODO_TOKEN=

# --- LLM for ideas / research / article (provider-agnostic) ---
# Point at kie.ai (Gemini), OpenAI, or Anthropic.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# --- Images: kie.ai (gpt-image-2 default, nano-banana-2 fallback) ---
KIE_API_KEY=

# --- Voice: ElevenLabs + Google Cloud TTS ---
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# --- Storage ---
GCS_BUCKET=

# --- Database ---
# Local dev uses SQLite (default below). Production uses Cloud SQL Postgres.
PIPELINE_DB=pipeline/lorewire.db
# DATABASE_URL=postgres://user:pass@host:5432/lorewire
