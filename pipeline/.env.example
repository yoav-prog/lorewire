# LoreWire pipeline — copy to pipeline/.env (gitignored) and fill in ROTATED keys.
# Never commit real values. The pipeline auto-loads pipeline/.env; exported
# shell variables take precedence over the file.

# --- LLM (ideas / research / article) ---
# OpenAI by default. To use another OpenAI-compatible endpoint (e.g. kie.ai
# Gemini), comment OPENAI_* and set LLM_API_KEY + LLM_BASE_URL + LLM_MODEL.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# --- Scrape: Reddit via Decodo proxy ---
DECODO_TOKEN=

# --- Images: kie.ai (gpt-image-2 default, nano-banana-2 fallback) ---
KIE_API_KEY=

# --- Voice: ElevenLabs + Google Cloud TTS ---
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# --- Storage ---
GCS_BUCKET=

# --- Database ---
PIPELINE_DB=pipeline/lorewire.db
# DATABASE_URL=postgres://user:pass@host:5432/lorewire
