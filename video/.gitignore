# Server build output (npm run build:server). Regenerated by the
# Dockerfile builder stage at deploy time; nothing in the repo's other
# tooling depends on the compiled JS being checked in.
dist/

# Local-only env (never commit secrets — Cloud Run reads its env from
# --set-env-vars at deploy time).
.env
.env.local
.env.*.local

# Editor scratch
.tsbuildinfo
