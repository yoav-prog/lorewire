# LoreWire env reference. Copy to .env.local (gitignored) and fill in values.
# The pipeline auto-loads /.env, /.env.local, then /pipeline/.env in order;
# exported shell vars win over files. The Next app loads /lorewire-app/.env.local.

# --- Required for the text pipeline ----------------------------------------
OPENAI_API_KEY=sk-...
DECODO_TOKEN=...                # residential-proxy Scraping API for Reddit

# --- Required for image generation -----------------------------------------
KIE_API_KEY=...                 # kie.ai (gpt-image-2 / nano-banana-* models)

# --- Required for voiceover (pick one of the providers below) --------------
# ElevenLabs (premium English, char-level alignment included in synth response)
ELEVENLABS_API_KEY=...

# Google Cloud Text-to-Speech + Speech-to-Text (Chirp 3 HD, Gemini TTS, Neural2)
# Same service account drives TTS synthesis and STT alignment.
GOOGLE_TTS_PROJECT_ID=
GOOGLE_TTS_CLIENT_EMAIL=
GOOGLE_TTS_PRIVATE_KEY=         # PEM with literal "\n" (Vercel footgun fix in code)

# --- Required for the production admin (Vercel) ----------------------------
# Set in the Vercel project env, NOT in any local file you ship.
# Generate SESSION_SECRET locally with:  python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Canonical site origin. The poll-vote and cookie-consent API routes
# fail closed in production when this is unset (every POST returns
# "forbidden origin"), so always set it on Vercel. Dev fallback accepts
# localhost regardless; setting it locally only matters if you run
# `next start` (NODE_ENV=production) against the dev DB.
#   dev:  http://localhost:3000
#   prod: https://lorewire.com  (or your canonical domain, no trailing slash)
NEXT_PUBLIC_SITE_ORIGIN=

# --- Public-user auth (2026-06-19 anonymous-first sign-in) -----------------
# All three providers are optional individually: a missing pair simply
# disables that sign-in button. Sign-in is broken entirely only when ALL
# three are unset. Plan: _plans/2026-06-19-anonymous-first-auth.md.
#
# Independent secret from SESSION_SECRET. Public-user JWT cookie
# `lw_user`. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
USER_SESSION_SECRET=
# Google OAuth. Console: https://console.cloud.google.com/apis/credentials
# Redirect URI to register: {NEXT_PUBLIC_SITE_ORIGIN}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft Entra ID OAuth. Console: Azure Portal → App registrations
# Redirect URI: {NEXT_PUBLIC_SITE_ORIGIN}/auth/microsoft/callback
# Tenant: leave as "common" to accept BOTH personal Microsoft accounts
# (Outlook/Hotmail/Live) AND work/school accounts. Use a tenant GUID to
# restrict to one organization. Plan: §Provider v1.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
# Brevo transactional email — magic-link delivery. Free tier covers
# ~9,000 emails/month (verified live 2026-06-19). Key: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@lorewire.com
BREVO_FROM_NAME=LoreWire

# Postgres connection string. When set, the pipeline + admin both switch from
# local SQLite to this database. Neon free tier on Vercel Marketplace is the
# recommended provisioning path; the URL Vercel auto-wires is the value here.
DATABASE_URL=

# --- Required for GCS-hosted media (production) ----------------------------
# Separate service account from GOOGLE_TTS_* per the security plan. Bucket
# must have allUsers:objectViewer at the bucket level (uniform bucket-level
# access). Pipeline assets land at https://storage.googleapis.com/<bucket>/...
GCS_BUCKET=                     # e.g. lorewire-generated
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=                # PEM with literal "\n"
GCS_CLIENT_ID=                  # optional; useful for telemetry only

# --- GitHub + Vercel CI tokens (local-only, for the deploy script) ---------
GITHUB=ghp_...                  # fine-grained PAT for yt-studio / newturbovid (reference repos)
GITHUB_TOKEN=ghp_...             # yoav-prog token used to push the lorewire repo
VERCEL_TOKEN=                    # team-scoped token (lore-wire) for env + deploy automation
